flowchart LR
    DOCS["Documents\nPDF - DOCX - HTML\nTXT - XLS - EML"] --> DR["domain_resolver.py\nSelect domain config"]
    SCHEMA["domain.yaml\nEntity types\nRelation types\nAliases"] --> EXT
    DR --> ING["ingest_documents.py\nParse + chunk"]
    ING --> EXT["build_extraction.py\nExtract entities +\nrelations via LLM"]
    EXT --> SIFT["run_sift.py\nBuild graph\nEntity resolution\nCommunity detection"]
    SIFT --> EPIS["epistemic.py\nEpistemic analysis\nConflicts - gaps - risks"]
    EPIS --> OUT["Output"]
    OUT --> VIZ["Interactive Viewer\nHTML graph"]
    OUT --> EXP["Export\nGraphML - SQLite - CSV"]
    OUT --> QRY["Search + Query"]
    OUT --> JSON["graph_data.json\nCommunities JSON"]
